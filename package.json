{
  "name": "frugl",
  "version": "0.2.3",
  "description": "Upload anonymized AI-coding session logs to hosted Frugl.",
  "keywords": [
    "ai",
    "anonymize",
    "cli",
    "coding",
    "frugl",
    "oclif",
    "telemetry"
  ],
  "homepage": "https://github.com/Frugl-dev/Frugl-cli#readme",
  "bugs": {
    "url": "https://github.com/Frugl-dev/Frugl-cli/issues"
  },
  "license": "MIT",
  "author": "Frugl",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Frugl-dev/Frugl-cli.git"
  },
  "man": "./man/frugl.1",
  "bin": {
    "frugl": "./bin/run.js"
  },
  "files": [
    "bin/run.js",
    "brand",
    "dist",
    "man/frugl.1",
    "oclif.manifest.json",
    "scripts/postinstall-man.mjs",
    "README.md",
    "LICENSE",
    "pnpm-workspace.yaml"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx bin/dev.js",
    "clean": "rm -rf dist oclif.manifest.json man",
    "build": "npm run clean && tsc -p tsconfig.build.json && oclif manifest && node scripts/build-manpage.mjs",
    "prepack": "npm run build",
    "postpack": "rm -f oclif.manifest.json",
    "postinstall": "node scripts/postinstall-man.mjs",
    "lint": "oxlint --ignore-pattern '.claude/**'",
    "lint:fix": "oxlint --fix --ignore-pattern '.claude/**'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pack:tarballs": "oclif pack tarballs --no-xz"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@napi-rs/keyring": "^1.3.0",
    "@oclif/core": "^4.11.11",
    "@oclif/plugin-help": "^6.2.53",
    "conf": "^15.1.0",
    "env-paths": "^4.0.0",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "semver": "^7.8.5",
    "temporal-polyfill": "^1.0.1",
    "tinyglobby": "^0.2.17",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/picomatch": "^4.0.3",
    "@types/retry": "^0.12.5",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "4.1.9",
    "oclif": "^4.23.24",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "pre-commit": "^2.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "pre-commit": [
    "format:check",
    "lint",
    "typecheck",
    "test"
  ],
  "oclif": {
    "additionalHelpFlags": [
      "-h"
    ],
    "additionalVersionFlags": [
      "-v"
    ],
    "bin": "frugl",
    "commands": "./dist/commands",
    "dirname": "frugl",
    "hooks": {
      "init": "./dist/hooks/init/hello"
    },
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "update": {
      "node": {
        "version": "26.4.0"
      }
    }
  },
  "engines": {
    "node": ">=22.5"
  },
  "packageManager": "pnpm@11.9.0"
}
