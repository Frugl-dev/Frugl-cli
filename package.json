{
  "name": "frugl",
  "version": "0.1.3",
  "description": "Upload anonymized AI-coding session logs to hosted Frugl.",
  "keywords": [
    "ai",
    "anonymize",
    "cli",
    "coding",
    "frugl",
    "oclif",
    "telemetry"
  ],
  "homepage": "https://github.com/Frugl-dev/Frugl-cli#readme",
  "bugs": {
    "url": "https://github.com/Frugl-dev/Frugl-cli/issues"
  },
  "license": "MIT",
  "author": "Frugl",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Frugl-dev/Frugl-cli.git"
  },
  "bin": {
    "frugl": "./bin/run.js"
  },
  "files": [
    "bin/run.js",
    "brand",
    "dist",
    "oclif.manifest.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx bin/dev.js",
    "clean": "rm -rf dist oclif.manifest.json",
    "build": "npm run clean && tsc -p tsconfig.build.json && oclif manifest",
    "prepack": "npm run build",
    "postpack": "rm -f oclif.manifest.json",
    "lint": "oxlint --ignore-pattern '.claude/**'",
    "lint:fix": "oxlint --fix --ignore-pattern '.claude/**'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@napi-rs/keyring": "^1.1.6",
    "@oclif/core": "^4.0.30",
    "conf": "^15.1.0",
    "env-paths": "^4.0.0",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "semver": "^7.6.3",
    "tinyglobby": "^0.2.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/picomatch": "^4.0.3",
    "@types/retry": "^0.12.5",
    "@types/semver": "^7.5.8",
    "oclif": "^4.15.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "pre-commit": "^2.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "pre-commit": [
    "format:check",
    "lint",
    "typecheck",
    "test"
  ],
  "oclif": {
    "bin": "frugl",
    "commands": "./dist/commands",
    "dirname": "frugl",
    "hooks": {
      "init": "./dist/hooks/init/hello"
    },
    "topicSeparator": " "
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.6.0"
}
