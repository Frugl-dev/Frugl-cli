{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frugl.app/schemas/v1/command-output.json",
  "title": "Frugl Command Output (v1)",
  "description": "Single structured JSON object emitted on stdout by 'login', 'logout', 'whoami' under --json (FR-040). Also describes the final manifest-summary object that is the LAST stdout line of 'frugl upload' (FR-038/039). FR-036 contract surface.",
  "oneOf": [
    { "$ref": "#/$defs/LoginResult" },
    { "$ref": "#/$defs/LogoutResult" },
    { "$ref": "#/$defs/WhoamiResultOk" },
    { "$ref": "#/$defs/WhoamiResultNotLoggedIn" },
    { "$ref": "#/$defs/UploadFinalSummary" }
  ],
  "$defs": {
    "LoginResult": {
      "type": "object",
      "required": ["command", "ok", "email", "endpoint"],
      "additionalProperties": false,
      "properties": {
        "command": { "const": "login" },
        "ok": { "const": true },
        "email": { "type": "string", "format": "email" },
        "endpoint": { "type": "string", "format": "uri" },
        "userId": { "type": "string" }
      }
    },
    "LogoutResult": {
      "type": "object",
      "required": ["command", "ok"],
      "additionalProperties": false,
      "properties": {
        "command": { "const": "logout" },
        "ok": { "const": true }
      }
    },
    "WhoamiResultOk": {
      "type": "object",
      "required": ["command", "ok", "email", "userId", "endpoint", "loggedInAt"],
      "additionalProperties": false,
      "properties": {
        "command": { "const": "whoami" },
        "ok": { "const": true },
        "email": { "type": "string", "format": "email" },
        "userId": { "type": "string" },
        "endpoint": { "type": "string", "format": "uri" },
        "loggedInAt": { "type": "string", "format": "date-time" }
      }
    },
    "WhoamiResultNotLoggedIn": {
      "type": "object",
      "required": ["command", "ok", "reason"],
      "additionalProperties": false,
      "properties": {
        "command": { "const": "whoami" },
        "ok": { "const": false },
        "reason": { "const": "not-logged-in" }
      }
    },
    "UploadFinalSummary": {
      "type": "object",
      "description": "The LAST line on stdout for 'frugl upload'. Present in BOTH text and --json modes (FR-038).",
      "required": [
        "command",
        "ok",
        "manifestId",
        "actualSessionCount",
        "expectedSessionCount",
        "redactionPolicyVersion",
        "sourceKind",
        "endpoint",
        "dashboardUrl",
        "classification",
        "limited"
      ],
      "additionalProperties": false,
      "properties": {
        "command": { "const": "upload" },
        "ok": { "const": true },
        "manifestId": { "type": "string" },
        "actualSessionCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Sessions actually acked by the cloud. Equals expectedSessionCount minus FR-027b skips."
        },
        "expectedSessionCount": { "type": "integer", "minimum": 1 },
        "skippedSessionCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Sessions in the manifest that were skipped on resume due to FR-027b (missing or modified source file)."
        },
        "redactionPolicyVersion": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+$" },
        "sourceKind": { "type": "string" },
        "endpoint": { "type": "string", "format": "uri" },
        "dashboardUrl": { "type": "string", "format": "uri" },
        "classification": {
          "type": "object",
          "required": ["discovered", "unchanged", "new", "updated"],
          "additionalProperties": false,
          "properties": {
            "discovered": { "type": "integer", "minimum": 0 },
            "unchanged": { "type": "integer", "minimum": 0 },
            "new": { "type": "integer", "minimum": 0 },
            "updated": { "type": "integer", "minimum": 0 }
          }
        },
        "limited": {
          "type": "object",
          "description": "Present in every summary. When --limit was NOT in effect, `active: false` and only the discovered counts populate.",
          "required": ["active"],
          "properties": {
            "active": { "type": "boolean" },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "description": "Only present when active=true."
            },
            "candidateCount": {
              "type": "integer",
              "minimum": 0,
              "description": "Size of (new ∪ updated) before --limit truncation. Only present when active=true."
            }
          }
        }
      }
    }
  }
}
