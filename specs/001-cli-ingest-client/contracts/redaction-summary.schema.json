{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poppi.app/schemas/v1/redaction-summary.json",
  "title": "Poppi Redaction Summary (v1)",
  "description": "Per-session, per-category counts of redactions applied by the anonymizer. Printed to stdout during --dry-run --inspect and (when --inspect dir is provided) written alongside each session's inspection payload. FR-019, FR-036 contract surface.",
  "type": "object",
  "required": ["redactionPolicyVersion", "sessions"],
  "additionalProperties": false,
  "properties": {
    "redactionPolicyVersion": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "sessions": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/SessionSummary" }
    },
    "totals": {
      "$ref": "#/$defs/CategoryCounts",
      "description": "Sum across all sessions in the batch. Present in the batch-level summary."
    }
  },
  "$defs": {
    "SessionSummary": {
      "type": "object",
      "required": ["sessionId", "sourceKind", "byteSizeBefore", "byteSizeAfter", "counts"],
      "additionalProperties": false,
      "properties": {
        "sessionId": { "type": "string" },
        "sourceKind": { "type": "string", "examples": ["claude-code"] },
        "byteSizeBefore": { "type": "integer", "minimum": 0 },
        "byteSizeAfter": { "type": "integer", "minimum": 0 },
        "counts": { "$ref": "#/$defs/CategoryCounts" }
      }
    },
    "CategoryCounts": {
      "type": "object",
      "description": "One key per redaction category. Categories with zero hits MAY be omitted. Unknown categories MUST be ignored by consumers (forward-compatibility).",
      "additionalProperties": { "type": "integer", "minimum": 0 },
      "properties": {
        "anthropic-key": { "type": "integer", "minimum": 0 },
        "openai-key": { "type": "integer", "minimum": 0 },
        "aws-key": { "type": "integer", "minimum": 0 },
        "gcp-key": { "type": "integer", "minimum": 0 },
        "github-token": { "type": "integer", "minimum": 0 },
        "slack-webhook": { "type": "integer", "minimum": 0 },
        "env-line": { "type": "integer", "minimum": 0 },
        "home-path": { "type": "integer", "minimum": 0 },
        "project-name": { "type": "integer", "minimum": 0 },
        "third-party-email": { "type": "integer", "minimum": 0 },
        "entropy-fallback": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
